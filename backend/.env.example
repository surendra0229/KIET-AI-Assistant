# ─────────────────────────────────────────────────────────────────────────────
# KIET AI Assistant — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in YOUR values below.
# 3. NEVER commit the .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development

# ─── Gemini (Google AI) ───────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── RAG Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5

# ─── Local Storage Paths ──────────────────────────────────────────────────────
DATA_DIR=./data
DOCUMENTS_DIR=./data/documents
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=college_docs

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=YOUR_MONGODB_CONNECTION_STRING_HERE
MONGODB_DB=college_ai

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a secure secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=GENERATE_A_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRE_MINUTES=7200

# ─── Super Admin Bootstrap ────────────────────────────────────────────────────
# Created automatically on first startup if the account does not exist.
SUPER_ADMIN_NAME=Your Full Name
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=ChooseAStrongPassword123!

# ─── SMTP (email delivery — optional, not yet integrated) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com
